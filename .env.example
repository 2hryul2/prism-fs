# prism-fs 환경변수 예시 — 실제 값은 .env 에만 (gitignore 등록됨)
# DART OpenAPI 키 (필수, 수집 기능 사용 시)
DART_API_KEY=

# 외부 LLM 옵트인 (선택) — 키가 있을 때만 활성. 기본은 로컬 Ollama.
OPENAI_API_KEY=

# 로컬 LLM (기본). Ollama 미가동 시 LLM 기능 자동 비활성.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# 임베딩 오프라인 강제 (폐쇄망)
HF_HUB_OFFLINE=1
